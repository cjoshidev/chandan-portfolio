# Turso (SQLite) — claps storage
# Get from: turso db show portfolio-claps --url
TURSO_DATABASE_URL=https://your-db.turso.io
# Get from: turso db tokens create portfolio-claps
TURSO_AUTH_TOKEN=your-turso-token

# Supabase — subscribers storage
# Get from: Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — email delivery
# Get from: resend.com > API Keys
RESEND_API_KEY=re_...

# Canonical site URL (no trailing slash)
VITE_SITE_URL=https://chandanjoshi.dev
